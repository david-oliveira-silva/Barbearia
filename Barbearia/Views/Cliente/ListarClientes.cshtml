@using DOMAIN.MODELS.CLIENTES
@model List<ClienteModel>

@{
	ViewData["Title"] = "Clientes Cadastrados";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-0">
                <i class="fa-solid fa-users me-2"></i> Cadastro de Clientes
            </h2>
            <p class="text-muted mb-0">Gerencie a sua base de clientes fiéis</p>
        </div>
        <a asp-controller="Cliente" asp-action="UpsertCliente" class="btn btn-dark btn-lg shadow-sm fw-bold px-4">
            <i class="fa-solid fa-user-plus me-2"></i> Novo Cliente
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow border-0 rounded-3 mb-4">
        <div class="card-body p-3">
            <form asp-controller="Cliente" asp-action="ListarClientes" method="get" class="row g-2">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fa-solid fa-search text-muted"></i>
                        </span>
                        <input type="text" name="nome" class="form-control border-start-0 ps-0 text-dark" placeholder="Buscar por nome do cliente..." />
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark w-100 fw-bold shadow-sm">Pesquisar</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-center py-3" style="width: 80px;">ID</th>
                            <th class="py-3">Nome</th>
                            <th class="py-3 text-center">CPF</th>
                            <th class="py-3">E-mail</th>
                            <th class="py-3 text-center">Telefone</th>
                            <th class="text-center py-3" style="width: 200px;">Opções</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cliente in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold text-muted">@cliente.IdCliente</td>
                                <td class="fw-bold text-dark">@cliente.Nome</td>
                                <td class="text-center text-muted">
                                    @(!string.IsNullOrEmpty(cliente.Cpf) ? long.Parse(cliente.Cpf).ToString(@"000\.000\.000-00") : "N/A")
                                </td>
                                <td><i class="fa-solid fa-envelope me-1 small text-muted"></i> @cliente.Email</td>
                                <td class="text-center">
                                    <i class="fa-solid fa-phone me-1 small text-muted"></i>
                                    @(!string.IsNullOrEmpty(cliente.Telefone) ? long.Parse(cliente.Telefone).ToString(@"(00) 00000-0000") : "N/A")
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a class="btn btn-outline-dark btn-sm px-3 fw-bold" asp-controller="Cliente" asp-action="UpsertCliente" asp-route-IdCliente="@cliente.IdCliente">
                                            <i class="fa-solid fa-user-pen"></i> Editar
                                        </a>
                                        <form asp-controller="Cliente" asp-action="ExcluirCliente" method="post" class="d-inline">
                                            <input type="hidden" name="IdCliente" value="@cliente.IdCliente" />
                                            <button type="submit" class="btn btn-danger btn-sm px-3 fw-bold shadow-sm" onclick="return confirm('Deseja realmente excluir o cliente @cliente.Nome?')">
                                                <i class="fa-solid fa-trash"></i> Excluir
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>