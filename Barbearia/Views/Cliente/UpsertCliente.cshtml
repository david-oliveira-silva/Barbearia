@model DOMAIN.MODELS.CLIENTES.ClienteModel

@{
    bool ehEdicao = Model.IdCliente != 0;
    ViewData["Title"] = (ehEdicao ? "Atualizar Cliente" : "Cadastrar Cliente");
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger mx-3 mt-3 shadow-sm border-0">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Erro"]
    </div>
}

<div class="container mt-5 mb-5">
    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-dark text-white p-3">
            <h4 class="mb-0 d-flex align-items-center">
                <i class="fa-solid @(ehEdicao ? "fa-user-pen" : "fa-user-plus") me-3"></i>
                <span>@(ehEdicao ? "Editar Informações do Cliente" : "Cadastro de Novo Cliente")</span>
            </h4>
        </div>
        <div class="card-body p-4">
            <form asp-controller="Cliente" asp-action=@(ehEdicao ? "EditarCliente" :"CadastrarCliente") method="post">
                <input type="hidden" asp-for="IdCliente" />

                <div class="row">
                    <div class="col-12 mb-4">
                        <label asp-for="Nome" class="form-label fw-bold">
                            <i class="fa-solid fa-user-tag me-2 text-muted"></i> Nome Completo
                        </label>
                        <input asp-for="Nome" class="form-control shadow-sm border-2" maxlength="100" placeholder="Ex: João da Silva" />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Cpf" class="form-label fw-bold">
                            <i class="fa-solid fa-id-card me-2 text-muted"></i> CPF
                        </label>
                        <input asp-for="Cpf" id="Cpf" maxlength="14" class="form-control shadow-sm border-2" placeholder="000.000.000-00" />
                        <span asp-validation-for="Cpf" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Telefone" class="form-label fw-bold">
                            <i class="fa-solid fa-phone me-2 text-muted"></i> Telefone
                        </label>
                        <input asp-for="Telefone" id="Telefone" maxlength="15" class="form-control shadow-sm border-2" placeholder="(00) 00000-0000" />
                        <span asp-validation-for="Telefone" class="text-danger small"></span>
                    </div>

                    <div class="col-12 mb-4">
                        <label asp-for="Email" class="form-label fw-bold">
                            <i class="fa-solid fa-envelope me-2 text-muted"></i> E-mail para contato
                        </label>
                        <input asp-for="Email" type="email" class="form-control shadow-sm border-2" placeholder="cliente@exemplo.com.br" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="pt-3 border-top mt-2 d-flex gap-3">
                    <button type="submit" class="btn btn-dark px-5 fw-bold shadow-sm transition-hover">
                        <i class="fa-solid fa-floppy-disk me-2"></i> Salvar
                    </button>
                    <a asp-controller="Cliente" asp-action="ListarClientes" class="btn btn-outline-dark px-4 border-2">
                        <i class="fa-solid fa-circle-arrow-left me-2"></i> Voltar para a lista
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/Mascaras/Mascara.js" asp-append-version="true"></script>