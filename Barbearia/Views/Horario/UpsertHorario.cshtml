@using DOMAIN.Enuns.Horario
@using DOMAIN.Models.ViewModelHorario
@using System.Globalization
@model ViewModelHorario

@{
	bool ehEdicao = Model?.Horario?.IdHorario > 0;
    ViewData["Title"] = (ehEdicao ? "Atualizar Horário" : "Cadastrar Horário");
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger mx-auto mt-3 shadow-sm border-0" style="max-width: 800px;">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Erro"]
    </div>
}

<div class="container mt-5 mb-5 d-flex justify-content-center">
	<div class="card shadow border-0 rounded-3 w-100" style="max-width: 800px;">
		<div class="card-header bg-dark text-white p-3">
			<h4 class="mb-0 d-flex align-items-center justify-content-center">
                <i class="fa-solid fa-calendar-plus me-3"></i>
                <span>@(ehEdicao ? "Editar Horário na Escala" : "Definir Novo Horário de Trabalho")</span>
            </h4>
		</div>
		<div class="card-body p-4">
			<form asp-controller="Horario" asp-action="@(ehEdicao ? "AtualizarHorario" : "CadastrarHorario")" method="post">
				<input type="hidden" asp-for="Horario.IdHorario" />
				@if (ehEdicao)
				{
					<input type="hidden" asp-for="Horario.IdBarbeiro" />
				}
				<div class="row">
					<div class="col-12 mb-4">
						<label asp-for="Horario.IdBarbeiro" class="form-label fw-bold text-muted mb-2">
                            <i class="fa-solid fa-user-tie me-2 text-dark"></i> Selecione o Barbeiro
                        </label>
						<select asp-for="Horario.IdBarbeiro" class="form-select shadow-sm border-2" disabled="@(ehEdicao ? "disabled" : null)">
							<option value="" disabled selected>Escolha um profissional...</option>
							@foreach (var barbeiro in Model?.Barbeiros ?? [])
							{
								<option value="@barbeiro.IdBarbeiro"> @barbeiro.Nome</option>
							}
						</select>
					</div>

					<div class="col-12 mb-4">
						<label asp-for="Horario.DiaSemana" class="form-label fw-bold text-muted mb-2">
                            <i class="fa-solid fa-calendar-days me-2 text-dark"></i> Dia da Semana
                        </label>
						<select asp-for="Horario.DiaSemana" class="form-select shadow-sm border-2">
							<option value="" disabled selected>Escolha o dia...</option>
							@foreach (DiaSemana dia in Enum.GetValues(typeof(DiaSemana)))
							{				
								<option value="@dia"> @dia</option>
							}
						</select>
					</div>

					<div class="col-6 mb-4">
						<label asp-for="Horario.HorarioInicio" class="form-label fw-bold text-muted mb-2">
                            <i class="fa-solid fa-clock me-2 text-dark"></i> Início do Turno
                        </label>
						<input asp-for="Horario.HorarioInicio" type="time" class="form-control shadow-sm border-2" />
					</div>

					<div class="col-6 mb-4">
						<label asp-for="Horario.HorarioFim" class="form-label fw-bold text-muted mb-2">
                            <i class="fa-solid fa-clock-rotate-left me-2 text-dark"></i> Término do Turno
                        </label>
						<input asp-for="Horario.HorarioFim" type="time" class="form-control shadow-sm border-2" />
					</div>

					<div class="col-12 mb-4">
						<label asp-for="Horario.Ativo" class="form-label d-block fw-bold text-muted mb-3">
                            <i class="fa-solid fa-toggle-on me-2 text-dark"></i> Status do Horário
                        </label>

						<div class="btn-group w-100 shadow-sm" role="group">
							<input type="radio" asp-for="Horario.Ativo" value="@Ativo.ATIVO" class="btn-check" id="ativoSim" autocomplete="off">
							<label class="btn btn-outline-dark border-2 fw-bold" for="ativoSim">
                                <i class="fa-solid fa-check-circle me-1"></i> ATIVO
                            </label>

							<input type="radio" asp-for="Horario.Ativo" value="@Ativo.INATIVO" class="btn-check" id="ativoNao" autocomplete="off">
							<label class="btn btn-outline-dark border-2 fw-bold" for="ativoNao">
                                <i class="fa-solid fa-circle-xmark me-1"></i> INATIVO
                            </label>
						</div>
					</div>

					<div class="col-12 mt-3 pt-3 border-top d-flex gap-2 justify-content-center">
						<button type="submit" class="btn btn-dark px-5 fw-bold shadow-sm transition-hover">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Salvar Escala
                        </button>
						<a class="btn btn-outline-dark px-4 border-2" asp-controller="Horario" asp-action="ListarHorarios">
                            <i class="fa-solid fa-xmark me-2"></i> Cancelar
                        </a>
					</div>
				</div>
			</form>
		</div>
	</div>
</div>
