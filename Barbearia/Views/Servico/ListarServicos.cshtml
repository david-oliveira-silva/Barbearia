@using DOMAIN.MODELS.SERVICOS
@model List<ServicoModel>

@{
	ViewData["Title"] = "Catálogo de Serviços";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-0">
                <i class="fa-solid fa-tags me-2"></i> Nosso Catálogo
            </h2>
            <p class="text-muted mb-0">Gerencie os serviços oferecidos e seus respectivos valores</p>
        </div>
        <a asp-controller="Servico" asp-action="UpsertServico" class="btn btn-dark btn-lg shadow-sm fw-bold px-4">
            <i class="fa-solid fa-circle-plus me-2"></i> Adicionar Novo Serviço
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow border-0 rounded-3 mb-4">
        <div class="card-body p-3">
            <form asp-controller="Servico" asp-action="ListarServicos" method="get" class="row g-2">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fa-solid fa-magnifying-glass text-muted"></i>
                        </span>
                        <input type="text" name="nome" class="form-control border-start-0 ps-0 text-dark" placeholder="Buscar por nome do serviço..." />
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark w-100 fw-bold">Pesquisar</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-center py-3" style="width: 80px;">ID</th>
                            <th class="py-3">Nome do Serviço</th>
                            <th class="py-3 text-center">Valor</th>
                            <th class="py-3 text-center">Tempo Médio</th>
                            <th class="text-center py-3" style="width: 200px;">Opções</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var servico in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold text-muted">@servico.IdServico</td>
                                <td class="fw-bold text-dark">
                                    <i class="fa-solid fa-check-circle text-success me-2 small"></i> @servico.Nome
                                </td>
                                <td class="text-center fw-bold text-primary fs-5">
                                    @servico.Valor.ToString("C2")
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border px-3 py-2 fs-6">
                                        <i class="fa-regular fa-clock me-1 text-muted"></i> @servico.TempoMedio.ToString("0 min")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a class="btn btn-outline-dark btn-sm px-3 fw-bold" asp-controller="Servico" asp-action="UpsertServico" asp-route-IdServico="@servico.IdServico">
                                            <i class="fa-solid fa-pen"></i> Editar
                                        </a>
                                        <form asp-controller="Servico" asp-action="ExcluirServico" method="post" class="d-inline">
                                            <input type="hidden" name="IdServico" value="@servico.IdServico" />
                                            <button type="submit" class="btn btn-danger btn-sm px-3 fw-bold shadow-sm" onclick="return confirm('Excluir o serviço @servico.Nome?')">
                                                <i class="fa-solid fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
