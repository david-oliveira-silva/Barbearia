@using DOMAIN.MODELS.SERVICOS
@model ServicoModel

@{
    bool ehEdicao = Model.IdServico != 0;
    ViewData["Title"] = (ehEdicao ? "Atualizar Serviço" : "Cadastrar Serviço");
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger mx-auto mt-3 shadow-sm border-0" style="max-width: 700px;">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Erro"]
    </div>
}

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="card shadow border-0 rounded-3 w-100" style="max-width: 700px;">
        <div class="card-header bg-dark text-white p-3 text-center">
            <h4 class="mb-0 d-flex align-items-center justify-content-center">
                <i class="fa-solid fa-briefcase me-3"></i>
                <span>@(ehEdicao ? "Atualizar Detalhes do Serviço" : "Cadastrar Novo Serviço")</span>
            </h4>
        </div>
        <div class="card-body p-4">
            <form asp-controller="Servico" asp-action=@(ehEdicao ? "AtualizarServico" :"CadastrarServico") method="post">
                <input type="hidden" asp-for="IdServico" />

                <div class="row">
                    <div class="col-12 mb-4">
                        <label asp-for="Nome" class="form-label fw-bold">
                            <i class="fa-solid fa-tag me-2 text-muted"></i> Nome do Serviço
                        </label>
                        <input asp-for="Nome" class="form-control shadow-sm border-2" maxlength="100" placeholder="Ex: Corte Degradê, Barba Completa..." />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Valor" class="form-label fw-bold">
                            <i class="fa-solid fa-dollar-sign me-2 text-muted"></i> Preço do Serviço
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-2 border-end-0">R$</span>
                            <input asp-for="Valor" class="form-control shadow-sm border-2 border-start-0" placeholder="0,00" />
                        </div>
                        <span asp-validation-for="Valor" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="TempoMedio" class="form-label fw-bold">
                            <i class="fa-solid fa-clock me-2 text-muted"></i> Tempo Previsto
                        </label>
                        <div class="input-group">
                            <input asp-for="TempoMedio" class="form-control shadow-sm border-2 border-end-0" placeholder="Ex: 30" />
                            <span class="input-group-text bg-light border-2 border-start-0">minutos</span>
                        </div>
                        <span asp-validation-for="TempoMedio" class="text-danger small"></span>
                    </div>
                </div>

                <div class="pt-3 border-top mt-2 d-flex gap-3 justify-content-center">
                    <button type="submit" class="btn btn-dark px-5 fw-bold shadow-sm transition-hover">
                        <i class="fa-solid fa-check-double me-2"></i> Salvar Serviço
                    </button>
                    <a asp-controller="Servico" asp-action="ListarServicos" class="btn btn-outline-dark px-4 border-2">
                        <i class="fa-solid fa-rotate-left me-2"></i> Voltar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
