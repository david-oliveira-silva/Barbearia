@using DOMAIN.MODELS.SERVICOS
@model ServicoModel

@{
    bool ehEdicao = Model.IdServico != 0;
    ViewData["Title"] = (ehEdicao ? "Atualizar serviço" : "Cadastrar serviço");
}

@if (TempData["Erro"] != null)
{
    <p class="alert alert-danger">@TempData["Erro"]</p>
}

<div class="container mt-5" style="max-width:60%";>
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">@(ehEdicao ? "Editar Servico" : "Novo Servico")</h3>
        </div>
        <div class="card-body">
            <form asp-controller="Servico" asp-action=@(ehEdicao ? "AtualizarServico" :"CadastrarServico") method="post">

                <input type="hidden" asp-for="IdServico" />

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="Nome" class="form-label fw-bold">Nome</label>
                        <input asp-for="Nome" class="form-control" maxlength="100" placeholder="Digite o nome..." />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Valor" class="form-label fw-bold">Valor</label>
                        <input asp-for="Valor" id="Valor" class="form-control" placeholder="R$ 00,00" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="TempoMedio" class="form-label fw-bold">Tempo médio</label>
                        <input asp-for="TempoMedio" id="Telefone" class="form-control" placeholder="0 min" />
                    </div>

                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4 fw-bold">Salvar</button>
                    <a asp-controller="Servico" asp-action="ListarServicos" class="btn btn-outline-secondary px-4">Voltar</a>
                </div>
            </form>
        </div>
    </div>
</div>
