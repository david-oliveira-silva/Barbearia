@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Barbearia</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Barbearia.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-scissors me-2 text-white"></i>
                    <span>BARBEARIA</span>
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav nav-pills gap-2">
                        <li class="nav-item">
                            <a class="nav-link px-3 @(controller == "Cliente" ? "active bg-white text-dark fw-bold" : "text-white opacity-75") rounded-pill" asp-controller="Cliente" asp-action="ListarClientes">
                                <i class="fa-solid fa-users me-1"></i> Clientes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 @(controller == "Barbeiro" ? "active bg-white text-dark fw-bold" : "text-white opacity-75") rounded-pill" asp-controller="Barbeiro" asp-action="ListarBarbeiros">
                                <i class="fa-solid fa-user-tie me-1"></i> Barbeiros
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 @(controller == "Servico" ? "active bg-white text-dark fw-bold" : "text-white opacity-75") rounded-pill" asp-controller="Servico" asp-action="ListarServicos">
                                <i class="fa-solid fa-layer-group me-1"></i> Serviços
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 @(controller == "Horario" ? "active bg-white text-dark fw-bold" : "text-white opacity-75") rounded-pill" asp-controller="Horario" asp-action="ListarHorarios">
                                <i class="fa-solid fa-calendar-days me-1"></i> Horários
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        <div class="container-fluid px-4">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top footer text-muted bg-white">
        <div class="container py-3">
            <p class="text-center mb-0">
                &copy; 2026 - Projeto desenvolvido por David Oliveira. Acesse o código-fonte no
                <a href="https://github.com/david-oliveira-silva/Barbearia" target="_blank">
                    <i class="fa-brands fa-github"></i> repositório no GitHub
                </a>.
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>